name: 🤖 Auto Update AI News
on:
  schedule:
    - cron: '0 */6 * * *'
  workflow_dispatch:
permissions:
  contents: write
jobs:
  update-news:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: '3.11'
      - run: python scripts/fetch_news.py
      - run: |
          git config user.name "Slime AI Bot"
          git config user.email "bot@slime-ai.app"
          git add js/data.js
          git diff --cached --quiet || git commit -m "🤖 Auto-update $(date)"
          git push
